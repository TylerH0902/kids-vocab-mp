.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1A1A2E 0%, #16213E 50%, #0F3460 100%);
  padding: 30rpx 28rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

/* ── Lang toggle ── */
.lang-row { display: flex; gap: 12rpx; align-self: flex-end; }
.lang-btn {
  padding: 8rpx 20rpx; border-radius: 30rpx;
  border: 2rpx solid #FFD700; color: #FFD700;
  font-size: 24rpx; font-weight: 700;
}
.lang-btn.active { background: #FFD700; color: #1A1A2E; }

/* ── Header ── */
.header {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.header-icon { font-size: 100rpx; line-height: 1; }
.header-title {
  font-size: 52rpx; font-weight: 900; color: #FFD700;
  text-shadow: 0 0 20rpx rgba(255,215,0,.5);
}

/* ── Stats bar ── */
.stats-bar {
  width: 100%; display: flex; align-items: center; justify-content: space-around;
  background: rgba(255,215,0,.1); border: 2rpx solid rgba(255,215,0,.3);
  border-radius: 20rpx; padding: 20rpx 16rpx;
}
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.stat-value { font-size: 30rpx; font-weight: 900; color: #FFD700; }
.stat-label { font-size: 22rpx; color: rgba(255,215,0,.6); }
.stat-divider { width: 2rpx; height: 50rpx; background: rgba(255,215,0,.25); }

/* ── Category ── */
.category { width: 100%; }
.cat-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx; padding: 0 4rpx;
}
.cat-label { font-size: 30rpx; font-weight: 800; color: #e2e8f0; }
.cat-count {
  font-size: 22rpx; color: rgba(255,215,0,.7); font-weight: 700;
  background: rgba(255,215,0,.12); padding: 4rpx 14rpx; border-radius: 20rpx;
}

/* ── Achievement grid ── */
.ach-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
}

.ach-card {
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex; flex-direction: column; gap: 8rpx;
  border: 2rpx solid transparent;
  transition: opacity 0.2s;
}

.ach-card.earned {
  background: linear-gradient(135deg, rgba(255,215,0,.18), rgba(255,165,0,.12));
  border-color: rgba(255,215,0,.6);
  box-shadow: 0 0 16rpx rgba(255,215,0,.15);
}

.ach-card.locked {
  background: rgba(255,255,255,.04);
  border-color: rgba(255,255,255,.1);
  opacity: 0.55;
}

.ach-icon { font-size: 56rpx; line-height: 1; }
.ach-title {
  font-size: 26rpx; font-weight: 800; color: #f1f5f9; line-height: 1.3;
}
.ach-card.locked .ach-title { color: rgba(241,245,249,.5); }

.ach-desc {
  font-size: 20rpx; color: rgba(241,245,249,.5); line-height: 1.4;
}

.ach-pts-wrap { margin-top: 4rpx; }
.ach-pts {
  font-size: 22rpx; font-weight: 800; color: #FFD700;
  background: rgba(255,215,0,.12); padding: 4rpx 12rpx; border-radius: 14rpx;
}
.ach-card.locked .ach-pts { color: rgba(255,215,0,.4); }

/* ── Back button ── */
.btn-back {
  margin-top: 20rpx; width: 100%; border-radius: 60rpx;
  background: rgba(255,215,0,.12);
  border: 2rpx solid rgba(255,215,0,.35);
  color: #FFD700; font-size: 32rpx; font-weight: 700;
  padding: 20rpx 0;
}
