.page { padding: 16rpx 24rpx 140rpx; min-height: 100vh; }

/* Progress */
.prog-row { display:flex; align-items:center; gap:14rpx; margin-bottom:20rpx; }
.prog-bar-wrap { flex:1; background:#e0e0e0; border-radius:10rpx; height:16rpx; overflow:hidden; }
.prog-bar-fill { background:#6C63FF; height:100%; border-radius:10rpx; transition:width 0.3s; }
.prog-text { font-size:30rpx; color:#888; white-space:nowrap; }

/* ── Screen 1: Question ── */
.book-label { display:block; font-size:26rpx; color:#aaa; margin-bottom:16rpx; }

.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(108,99,255,.1);
  margin-bottom: 28rpx;
  min-height: 200rpx;
  display: flex;
  align-items: center;
}
.question-text {
  font-size: 38rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.6;
}

.speak-row { display:flex; justify-content:center; margin-bottom:28rpx; }
.replay-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #EEF;
  border: 2rpx solid #6C63FF;
  color: #6C63FF;
  font-size: 34rpx;
  font-weight: 700;
  padding: 18rpx 40rpx;
  border-radius: 60rpx;
  transition: opacity 0.2s;
}
.replay-btn.speaking { opacity: 0.45; }

.next-screen-btn {
  background: #6C63FF;
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 24rpx;
}

/* ── Screen 2: Choices ── */
.q-reminder {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,.06);
}
.q-reminder-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.q-reminder-speak { font-size: 36rpx; flex-shrink: 0; }

.choices-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.choice-block {
  background: #fff;
  border: 3rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 20rpx 14rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-height: 160rpx;
}
.choice-block.correct { border-color: #4CAF50; background: #e8f8e8; }
.choice-block.wrong   { border-color: #f44336; background: #fee8e8; }

.choice-letter {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #6C63FF; color: #fff;
  font-size: 30rpx; font-weight: 800;
  text-align: center; line-height: 56rpx;
  flex-shrink: 0;
}
.choice-block.correct .choice-letter { background: #4CAF50; }
.choice-block.wrong   .choice-letter { background: #f44336; }

.choice-text {
  font-size: 28rpx; color: #333;
  line-height: 1.4; text-align: center;
  flex: 1;
}
.choice-speak { font-size: 34rpx; }

/* Feedback */
.feedback {
  position: fixed; bottom:0; left:0; right:0;
  padding: 24rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
  z-index: 99;
}
.feedback.correct { background: #4CAF50; }
.feedback.wrong   { background: #f44336; }
.fb-text  { color:#fff; font-size:34rpx; font-weight:700; }
.fb-next  { color:#fff; font-size:32rpx; font-weight:700; padding:10rpx 18rpx; }
