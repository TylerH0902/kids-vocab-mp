.page { padding: 16rpx 24rpx 140rpx; min-height: 100vh; }

/* Progress */
.prog-row { display:flex; align-items:center; gap:14rpx; margin-bottom:20rpx; }
.prog-bar-wrap { flex:1; background:#e0e0e0; border-radius:10rpx; height:16rpx; overflow:hidden; }
.prog-bar-fill { background:#6C63FF; height:100%; border-radius:10rpx; transition:width 0.3s; }
.prog-text { font-size:30rpx; color:#888; white-space:nowrap; }

/* ── Screen 1: Question ── */
.book-label { display:block; font-size:26rpx; color:#aaa; margin-bottom:16rpx; }

.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(108,99,255,.1);
  margin-bottom: 28rpx;
  min-height: 220rpx;
  display: flex;
  align-items: center;
}
.question-text { font-size: 38rpx; font-weight: 600; color: #333; line-height: 1.6; }

.speak-row { display:flex; justify-content:center; margin-bottom:24rpx; }
.replay-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #EEF;
  border: 2rpx solid #6C63FF;
  color: #6C63FF;
  font-size: 34rpx;
  font-weight: 700;
  padding: 18rpx 40rpx;
  border-radius: 60rpx;
  transition: opacity 0.2s;
}
.replay-btn.speaking { opacity: 0.4; }

.swipe-hint { text-align:center; font-size:26rpx; color:#bbb; }

/* ── Screen 2: Choices ── */
.choices-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}
.choice-block {
  background: #fff;
  border: 3rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 24rpx 14rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-height: 200rpx;
  justify-content: space-between;
}
.choice-block.correct { border-color: #4CAF50; background: #e8f8e8; animation: correctBounce .45s ease; }
.choice-block.wrong   { border-color: #f44336; background: #fee8e8; animation: wrongShake .4s ease; }

.choice-letter {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #6C63FF; color: #fff;
  font-size: 38rpx; font-weight: 800;
  text-align: center; line-height: 72rpx;
  flex-shrink: 0;
}
.choice-block.correct .choice-letter { background: #4CAF50; }
.choice-block.wrong   .choice-letter { background: #f44336; }

.choice-text {
  font-size: 28rpx; color: #333;
  line-height: 1.4; text-align: center;
  flex: 1; width: 100%;
}
.choice-speak { font-size: 38rpx; }

/* Animations */
@keyframes correctBounce {
  0%   { transform: scale(1); }
  35%  { transform: scale(1.1); }
  65%  { transform: scale(.97); }
  100% { transform: scale(1); }
}
@keyframes wrongShake {
  0%,100% { transform: translateX(0); }
  20%     { transform: translateX(-12rpx); }
  40%     { transform: translateX(12rpx); }
  60%     { transform: translateX(-8rpx); }
  80%     { transform: translateX(8rpx); }
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

/* Feedback */
.feedback {
  position: fixed; bottom:0; left:0; right:0;
  padding: 24rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
  z-index: 99;
  animation: slideUp .3s ease;
}
.feedback.correct { background: #4CAF50; }
.feedback.wrong   { background: #f44336; }
.fb-text  { color:#fff; font-size:34rpx; font-weight:700; }
.fb-next  { color:#fff; font-size:32rpx; font-weight:700; padding:10rpx 18rpx; }
