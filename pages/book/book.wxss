.page { padding: 16rpx 20rpx 120rpx; min-height: 100vh; }

.prog-row { display:flex; align-items:center; gap:14rpx; margin-bottom:16rpx; }
.prog-bar-wrap { flex:1; background:#e0e0e0; border-radius:10rpx; height:14rpx; overflow:hidden; }
.prog-bar-fill { background:#6C63FF; height:100%; border-radius:10rpx; transition:width 0.3s; }
.prog-text { font-size:24rpx; color:#888; white-space:nowrap; }

.question-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.07);
}
.book-label { display:block; font-size:22rpx; color:#999; margin-bottom:10rpx; }
.question-text { display:block; font-size:28rpx; font-weight:600; color:#333; line-height:1.5; }

.choices-list { display:flex; flex-direction:column; gap:14rpx; }
.choice-row {
  display: flex;
  align-items: center;
  background: #fff;
  border: 3rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
  gap: 16rpx;
}
.choice-row.correct { border-color: #4CAF50; background: #e8f8e8; }
.choice-row.wrong   { border-color: #f44336; background: #fee8e8; }
.choice-letter {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #6C63FF; color: #fff;
  font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; text-align: center; line-height: 44rpx;
}
.choice-row.correct .choice-letter { background: #4CAF50; }
.choice-row.wrong   .choice-letter { background: #f44336; }
.choice-text { font-size: 26rpx; color: #333; line-height: 1.4; flex: 1; }

.feedback {
  position: fixed; bottom:0; left:0; right:0;
  padding: 20rpx 24rpx;
  display: flex; align-items: center; justify-content: space-between;
  z-index: 99;
}
.feedback.correct { background: #4CAF50; }
.feedback.wrong   { background: #f44336; }
.fb-text  { color:#fff; font-size:28rpx; font-weight:700; }
.fb-next  { color:#fff; font-size:28rpx; font-weight:700; padding:10rpx 16rpx; }
