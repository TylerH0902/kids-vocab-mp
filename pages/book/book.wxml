<view class="page">

  <!-- Lang toggle -->
  <view class="lang-row">
    <view class="lang-btn {{lang==='en'?'active':''}}" bindtap="setLang" data-val="en">EN</view>
    <view class="lang-btn {{lang==='zh'?'active':''}}" bindtap="setLang" data-val="zh">中</view>
  </view>

  <!-- Progress -->
  <view class="prog-row">
    <view class="prog-bar-wrap">
      <view class="prog-bar-fill" style="width:{{progress}}%"></view>
    </view>
    <text class="prog-text">{{qIndex+1}} / {{total}}</text>
  </view>

  <!-- Question -->
  <text class="book-label">{{bookEmoji}} {{bookTitle}}</text>
  <view class="question-card">
    <text class="question-text">{{question}}</text>
  </view>
  <view class="speak-row">
    <view class="replay-btn {{speaking?'speaking':''}}" bindtap="speakQuestion">
      🔊 {{speaking ? '...' : replayLabel}}
    </view>
  </view>

  <!-- Choices -->
  <view class="choices-list">
    <view
      wx:for="{{choices}}"
      wx:key="id"
      class="choice-row choice-{{item.letter}} {{item.state}}"
      style="animation-delay: {{item.state ? '0' : item.delay}}ms"
      bindtap="onChoiceTap"
      data-id="{{item.id}}"
    >
      <text class="choice-letter">{{item.letter}}</text>
      <text class="choice-text">{{item.label}}</text>
    </view>
  </view>

  <!-- Fireworks overlay -->
  <view class="fw-wrap" wx:if="{{fireworks.length}}">
    <view class="fw-flash"></view>
    <view wx:for="{{fireworks}}" wx:key="id"
      class="fw-dot {{item.circle ? 'fw-circle' : 'fw-square'}}"
      style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}px;height:{{item.size}}px;background:{{item.color}};animation-duration:{{item.dur}}ms;animation-delay:{{item.delay}}ms;">
    </view>
  </view>

  <!-- Feedback bar -->
  <view class="feedback {{feedbackState}}" wx:if="{{feedbackVisible}}">
    <text class="fb-text">{{feedbackText}}</text>
    <view class="fb-next" bindtap="nextQuestion">{{qIndex+1 >= total ? doneLabel : nextLabel}} →</view>
  </view>

</view>
