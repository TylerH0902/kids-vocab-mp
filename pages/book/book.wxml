<view
  class="page"
  bindtouchstart="onTouchStart"
  bindtouchend="onTouchEnd"
>

  <!-- Progress -->
  <view class="prog-row">
    <view class="prog-bar-wrap">
      <view class="prog-bar-fill" style="width:{{progress}}%"></view>
    </view>
    <text class="prog-text">{{qIndex+1}} / {{total}}</text>
  </view>

  <!-- SCREEN 1: Question -->
  <block wx:if="{{step==='question'}}">
    <text class="book-label">{{bookEmoji}} {{bookTitle}}</text>
    <view class="question-card">
      <text class="question-text">{{question}}</text>
    </view>
    <view class="speak-row">
      <view class="replay-btn {{speaking?'speaking':''}}" bindtap="speakQuestion">
        🔊 {{speaking ? '...' : replayLabel}}
      </view>
    </view>
    <view class="swipe-hint">← {{swipeHint}} →</view>
  </block>

  <!-- SCREEN 2: Choices -->
  <block wx:if="{{step==='choices'}}">
    <view class="choices-grid">
      <view
        wx:for="{{choices}}"
        wx:key="id"
        class="choice-block {{item.state}}"
        bindtap="onChoiceTap"
        data-id="{{item.id}}"
      >
        <text class="choice-letter">{{item.letter}}</text>
        <text class="choice-text" wx:if="{{item.revealed}}">{{item.label}}</text>
        <view class="choice-speak" catchtap="speakChoice" data-label="{{item.label}}">🔊</view>
      </view>
    </view>

    <!-- Feedback + Next -->
    <view class="feedback {{feedbackState}}" wx:if="{{feedbackVisible}}">
      <text class="fb-text">{{feedbackText}}</text>
      <view class="fb-next" bindtap="nextQuestion">{{qIndex+1 >= total ? doneLabel : nextLabel}} →</view>
    </view>
  </block>

</view>
