<view class="page">

  <!-- Confetti -->
  <view class="confetti-wrap">
    <view
      wx:for="{{confetti}}"
      wx:key="id"
      class="confetto {{item.shape}}"
      style="left:{{item.x}}%;animation-delay:{{item.delay}}s;animation-duration:{{item.dur}}s;background:{{item.color}};width:{{item.size}}rpx;height:{{item.size}}rpx"
    ></view>
  </view>

  <!-- Lang toggle -->
  <view class="lang-row">
    <view class="lang-btn {{lang==='en'?'active':''}}" bindtap="setLang" data-val="en">EN</view>
    <view class="lang-btn {{lang==='zh'?'active':''}}" bindtap="setLang" data-val="zh">中</view>
  </view>

  <text class="result-emoji">{{emoji}}</text>
  <text class="result-title">{{title}}</text>
  <text class="result-score">{{scoreText}}</text>
  <view class="score-bar-wrap">
    <view class="score-bar-fill" style="width:{{pct}}%"></view>
  </view>
  <text class="pct-text">{{pct}}%</text>

  <view class="quest-banner {{questPassed?'quest-pass':'quest-retry'}}" wx:if="{{showQuestBanner}}">
    <text class="quest-banner-text">{{questBannerText}}</text>
  </view>

  <button class="btn-primary action-btn" bindtap="playAgain">{{playAgainLabel}}</button>
  <button class="btn-secondary action-btn" bindtap="goHome">{{homeLabel}}</button>

</view>
