.page {
  padding: 30rpx 40rpx 60rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(160deg, #FFF8F0 0%, #F0F8FF 100%);
  position: relative;
  overflow: hidden;
}

/* ── Confetti ── */
.confetti-wrap {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 0;
}

@keyframes confettiFall {
  0%   { transform: translateY(-20rpx) rotate(0deg);   opacity: 1; }
  75%  { opacity: 1; }
  100% { transform: translateY(110vh)  rotate(600deg); opacity: 0; }
}

.confetto {
  position: absolute;
  top: -20rpx;
  animation: confettiFall ease-in both;
}
.confetto.circle { border-radius: 50%; }
.confetto.square { border-radius: 4rpx; }

.lang-row { display: flex; gap: 12rpx; align-self: flex-end; margin-bottom: 8rpx; }
.lang-btn {
  padding: 8rpx 20rpx; border-radius: 30rpx;
  border: 2rpx solid #FF6B35; color: #FF6B35;
  font-size: 24rpx; font-weight: 700;
}
.lang-btn.active { background: #FF6B35; color: #fff; }
.result-emoji { font-size: 130rpx; line-height: 1; }
.result-title { font-size: 52rpx; font-weight: 800; color: #FF6B35; }
.result-score { font-size: 38rpx; color: #555; }
.score-bar-wrap {
  width: 100%; background: #e8e8e8;
  border-radius: 12rpx; height: 22rpx; overflow: hidden;
}
.score-bar-fill {
  background: linear-gradient(90deg, #FF6B35, #FFD93D);
  height: 100%; border-radius: 12rpx; transition: width 0.6s;
}
.pct-text { font-size: 34rpx; color: #FF6B35; font-weight: 700; }
.quest-banner {
  width: 100%; border-radius: 20rpx;
  padding: 22rpx 28rpx;
  text-align: center;
}
.quest-pass  { background: linear-gradient(135deg, #00C853, #00E676); }
.quest-retry { background: linear-gradient(135deg, #FF6D00, #FF9100); }
.quest-banner-text {
  font-size: 28rpx; font-weight: 800; color: #fff;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.2);
  line-height: 1.5;
}

.action-btn {
  width: 100%; border-radius: 60rpx;
  font-size: 36rpx; font-weight: 800; padding: 22rpx 0;
  box-shadow: 0 6rpx 20rpx rgba(255,107,53,.3);
}
.btn-new-quest {
  background: linear-gradient(135deg, #a855f7, #7c3aed);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(124,58,237,.35);
}

.ach-toast {
  background: linear-gradient(135deg, #FFD700, #FF9500);
  border-radius: 16rpx; padding: 16rpx 24rpx;
  width: 100%; text-align: center;
}
.ach-toast-text { font-size: 28rpx; font-weight: 800; color: #fff; }
.ach-balance { text-align: center; }
.ach-balance-text { font-size: 26rpx; color: #FFD700; font-weight: 700; }
