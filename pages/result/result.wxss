.page {
  padding: 60rpx 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.result-emoji { font-size: 130rpx; line-height: 1; }
.result-title { font-size: 52rpx; font-weight: 800; color: #6C63FF; }
.result-score { font-size: 38rpx; color: #555; }
.score-bar-wrap {
  width: 100%; background: #e0e0e0;
  border-radius: 12rpx; height: 22rpx; overflow: hidden;
}
.score-bar-fill { background: #6C63FF; height: 100%; border-radius: 12rpx; transition: width 0.6s; }
.pct-text { font-size: 34rpx; color: #888; }
.action-btn { width: 100%; border-radius: 20rpx; font-size: 36rpx; font-weight: 700; padding: 22rpx 0; }
