page { background: #080C24; }

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(160deg, #0D1840 0%, #1A0A2E 100%);
}

/* Coloured top band with emoji floating over it */
.header-band {
  width: 100%;
  height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 0;
  border-radius: 0 0 60% 60% / 0 0 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.4);
  position: relative;
}

/* Lang toggle sits top-right of the band */
.lang-row {
  position: absolute;
  top: 20rpx; right: 24rpx;
  display: flex; gap: 10rpx;
}
.lang-btn {
  padding: 6rpx 18rpx; border-radius: 30rpx;
  border: 2rpx solid rgba(255,255,255,0.7);
  color: rgba(255,255,255,0.85);
  font-size: 22rpx; font-weight: 700;
}
.lang-btn.active {
  background: rgba(255,255,255,0.95);
  color: #333;
}

.big-emoji {
  font-size: 160rpx;
  line-height: 1;
  margin-bottom: -60rpx;  /* floats over the card */
  filter: drop-shadow(0 8rpx 16rpx rgba(0,0,0,0.35));
}

/* Main card */
.card {
  width: 660rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 90rpx 44rpx 48rpx;
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.35);
}

.book-title {
  font-size: 46rpx;
  font-weight: 800;
  color: #1a1a2e;
  text-align: center;
  line-height: 1.3;
}

.book-sub {
  font-size: 28rpx;
  color: #888;
  text-align: center;
}

/* Stats */
.stats-row {
  display: flex;
  gap: 24rpx;
  margin: 10rpx 0 4rpx;
}

.stat-badge {
  flex: 1;
  background: #f5f5ff;
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 900;
  color: #333;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
}

/* Start button */
.start-btn {
  width: 100%;
  padding: 30rpx 0;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.2);
}

.start-text {
  color: #fff;
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

/* Stars + best score (single book) */
.stars-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 12rpx;
}
.star {
  font-size: 42rpx;
  color: #DDD;
}
.star.filled { color: #FFD700; }
.best-score {
  font-size: 24rpx;
  color: #888;
  margin-left: 10rpx;
}

/* Chapter picker (series books like Alice) */
.chapter-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 8rpx 0 16rpx;
}

.chapter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f5ff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 28rpx 24rpx;
  border-left: 8rpx solid #6C63FF;
}

.chapter-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.chapter-sub {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.ch-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chapter-count {
  font-size: 22rpx;
  color: #999;
}

.ch-stars {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.ch-star {
  font-size: 28rpx;
  color: #DDD;
}

.ch-star.filled { color: #FFD700; }

.ch-best {
  font-size: 20rpx;
  color: #aaa;
  margin-left: 6rpx;
}

.chapter-arrow {
  font-size: 48rpx;
  color: #bbb;
  font-weight: 300;
}

/* New-content banner */
.new-banner {
  width: 100%;
  background: linear-gradient(90deg, #FF4757, #FF6B35);
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.new-banner-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

/* Chapter new-count badge */
.ch-new-badge {
  background: #FF4757;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  margin-right: 10rpx;
}
.ch-new-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

/* Back link */
.back-link {
  font-size: 26rpx;
  color: #aaa;
  margin-top: 4rpx;
  padding: 10rpx 20rpx;
}
