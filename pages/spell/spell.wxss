.page { padding: 16rpx 20rpx 40rpx; min-height: 100vh; }

.prog-row { display:flex; align-items:center; gap:14rpx; margin-bottom:16rpx; }
.prog-bar-wrap { flex:1; background:#e0e0e0; border-radius:10rpx; height:14rpx; overflow:hidden; }
.prog-bar-fill { background:#6C63FF; height:100%; border-radius:10rpx; transition:width 0.3s; }
.prog-text { font-size:24rpx; color:#888; white-space:nowrap; }

.picture-zone {
  background:#fff; border-radius:24rpx;
  box-shadow:0 4rpx 20rpx rgba(0,0,0,.08);
  padding:20rpx; text-align:center; margin-bottom:20rpx;
  min-height:200rpx; display:flex; flex-direction:column;
  align-items:center; justify-content:center;
}
.pic-img { width:160rpx; height:160rpx; }
.big-emoji { font-size:110rpx; line-height:1; }
.zh-hint { font-size:28rpx; color:#888; margin-top:8rpx; }

.input-row { margin-bottom:16rpx; }
.spell-input {
  width:100%; border:4rpx solid #e8e8e8; border-radius:16rpx;
  padding:18rpx 20rpx; font-size:34rpx; font-weight:700;
  background:#fff; text-align:center; box-sizing:border-box;
}
.spell-input.correct { border-color:#4CAF50; background:#e8f8e8; }
.spell-input.wrong   { border-color:#f44336; background:#fee8e8; }

.feedback-row { text-align:center; margin-bottom:16rpx; }
.fb-text { font-size:30rpx; font-weight:700; }
.fb-text.correct { color:#4CAF50; }
.fb-text.wrong   { color:#f44336; }

.action-btn { border-radius:20rpx; font-size:32rpx; font-weight:700; padding:18rpx 0; }
.back-row { margin-top:20rpx; text-align:center; }
.back-btn { color:#999; font-size:26rpx; }
