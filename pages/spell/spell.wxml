<view class="page">

  <view class="prog-row">
    <view class="prog-bar-wrap">
      <view class="prog-bar-fill" style="width:{{progress}}%"></view>
    </view>
    <text class="prog-text">{{qIndex+1}} / {{total}}</text>
  </view>

  <!-- Word picture / emoji -->
  <view class="picture-zone" bindtap="speakWord">
    <image wx:if="{{picUrl}}" class="pic-img" src="{{picUrl}}" mode="aspectFit" />
    <text wx:elif="{{picLoading}}" class="big-emoji">⏳</text>
    <text wx:else class="big-emoji">{{currentWord.emoji}}</text>
    <text class="zh-hint">{{currentWord.zh}} 🔊</text>
  </view>

  <!-- Input -->
  <view class="input-row">
    <input
      class="spell-input {{inputState}}"
      value="{{inputVal}}"
      bindinput="onInput"
      placeholder="{{placeholder}}"
      focus="{{true}}"
      confirm-type="done"
      bindconfirm="checkSpell"
      disabled="{{answered}}"
    />
  </view>

  <!-- Feedback -->
  <view class="feedback-row" wx:if="{{answered}}">
    <text class="fb-text {{feedbackState}}">{{feedbackText}}</text>
  </view>

  <button class="btn-primary action-btn" bindtap="{{answered?'nextWord':'checkSpell'}}">
    {{answered ? nextLabel : checkLabel}}
  </button>

  <view class="back-row" wx:if="{{showBack}}">
    <view class="back-btn" bindtap="goHome">← {{homeLabel}}</view>
  </view>

</view>
