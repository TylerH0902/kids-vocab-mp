page { background: #0D1840; }

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0D1840 0%, #1A0A2E 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
}

/* ── Header ── */
.header {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx 48rpx;
  background: linear-gradient(160deg, #1E2A5E 0%, #2A0E4E 100%);
  border-radius: 0 0 60rpx 60rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.35);
  margin-bottom: 32rpx;
}

.lang-row {
  display: flex; gap: 12rpx;
  align-self: flex-end;
  margin-bottom: 30rpx;
}
.lang-btn {
  padding: 6rpx 20rpx; border-radius: 30rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
  color: rgba(255,255,255,0.8);
  font-size: 22rpx; font-weight: 700;
}
.lang-btn.active { background: rgba(255,255,255,0.9); color: #1A0A2E; }

.avatar-wrap {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FFD93D);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(255,107,53,0.45);
  margin-bottom: 20rpx;
  overflow: hidden;
}
.avatar-img    { width: 140rpx; height: 140rpx; border-radius: 50%; }
.avatar-letter { font-size: 72rpx; font-weight: 900; color: #fff; }

.nickname {
  font-size: 42rpx; font-weight: 800;
  color: #fff; margin-bottom: 14rpx;
}
.login-badge {
  font-size: 22rpx; color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.12);
  padding: 6rpx 22rpx; border-radius: 20rpx;
}

/* ── Summary cards ── */
.summary-row {
  display: flex; gap: 18rpx;
  width: 690rpx;
  margin-bottom: 36rpx;
}
.summary-card {
  flex: 1;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  padding: 24rpx 10rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.summary-num {
  font-size: 48rpx; font-weight: 900; color: #FFD93D;
}
.summary-label {
  font-size: 20rpx; color: rgba(255,255,255,0.55);
  text-align: center;
}

/* ── Section title ── */
.section-title {
  width: 690rpx;
  font-size: 26rpx; font-weight: 700;
  color: rgba(255,255,255,0.45);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

/* ── Book list ── */
.book-list {
  width: 690rpx;
  display: flex; flex-direction: column; gap: 16rpx;
  margin-bottom: 48rpx;
}

.book-row {
  display: flex; align-items: center; gap: 20rpx;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  padding: 24rpx 26rpx;
}
.book-row.unplayed {
  opacity: 0.5;
}

.book-emoji { font-size: 52rpx; flex-shrink: 0; }

.book-info {
  flex: 1;
  display: flex; flex-direction: column; gap: 6rpx;
}
.book-title {
  font-size: 28rpx; font-weight: 700; color: #fff;
}
.book-sub { font-size: 22rpx; color: rgba(255,255,255,0.45); }

.stars-row { display: flex; align-items: center; gap: 4rpx; margin-top: 4rpx; }
.star { font-size: 30rpx; color: rgba(255,255,255,0.2); }
.star.filled { color: #FFD700; }
.pct-text { font-size: 22rpx; color: rgba(255,255,255,0.5); margin-left: 8rpx; }

.book-right {
  display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx;
  flex-shrink: 0;
}
.score-big { font-size: 32rpx; font-weight: 800; color: #FFD93D; }
.attempts  { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.not-played { font-size: 22rpx; color: rgba(255,255,255,0.3); }

/* ── Logout ── */
.logout-btn {
  font-size: 28rpx; color: rgba(255,100,100,0.7);
  padding: 20rpx 60rpx;
  border: 1rpx solid rgba(255,100,100,0.3);
  border-radius: 40rpx;
}
