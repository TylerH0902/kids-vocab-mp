.page { padding: 24rpx 24rpx 48rpx; min-height: 100vh; }

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.title { font-size: 46rpx; font-weight: 800; color: #6C63FF; }

.lang-row { display: flex; gap: 12rpx; }
.lang-btn {
  padding: 10rpx 24rpx; border-radius: 30rpx;
  border: 2rpx solid #6C63FF; color: #6C63FF;
  font-size: 28rpx; font-weight: 700;
}
.lang-btn.active { background: #6C63FF; color: #fff; }

.book-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.07);
  gap: 18rpx;
}
.book-emoji { font-size: 60rpx; line-height: 1; flex-shrink: 0; }
.book-info { flex: 1; min-width: 0; }
.book-title {
  display: block;
  font-size: 36rpx; font-weight: 700; color: #333;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.book-sub { display: block; font-size: 28rpx; color: #999; margin-top: 6rpx; }
.book-arrow { font-size: 48rpx; color: #ccc; flex-shrink: 0; }
