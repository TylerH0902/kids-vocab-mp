page { background: #6A8050; }

.page {
  position: relative;
  width: 750rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow-x: hidden;
  background: #6A8050;
}

.planet-canvas {
  width: 750rpx;
  height: 940rpx;
  display: block;
  flex-shrink: 0;
}

/* Placeholder shown while canvas initialises — matches map colours */
.map-loader {
  position: absolute;
  top: 0; left: 0;
  width: 750rpx;
  height: 940rpx;
  background: linear-gradient(160deg, #C4D890 0%, #A0C060 45%, #7AAA42 100%);
  z-index: 5;
}

/* Header floats on top of canvas */
.header-overlay {
  position: absolute;
  top: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 24rpx 30rpx 0;
  z-index: 10;
}

.header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 14rpx; }
.lang-row { display: flex; gap: 12rpx; }
.lang-btn {
  padding: 8rpx 22rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255,217,61,0.7);
  color: #FFD93D;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(0,0,0,0.28);
}
.lang-btn.active {
  background: #FFD93D;
  color: #5A3010;
}

.profile-btn {
  font-size: 36rpx;
  background: rgba(0,0,0,0.30);
  border-radius: 50%;
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
}

.hint {
  font-size: 26rpx;
  color: rgba(60,40,10,0.65);
  margin-top: 12rpx;
  text-align: center;
  letter-spacing: 1rpx;
  transition: opacity 0.5s ease;
  opacity: 1;
}
.hint-hidden { opacity: 0; }
