.page { padding: 20rpx 20rpx 40rpx; min-height: 100vh; }

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.title { font-size: 36rpx; font-weight: 800; color: #6C63FF; }

.lang-row { display: flex; gap: 10rpx; }
.lang-btn {
  padding: 8rpx 18rpx; border-radius: 30rpx;
  border: 2rpx solid #6C63FF; color: #6C63FF;
  font-size: 22rpx; font-weight: 700;
}
.lang-btn.active { background: #6C63FF; color: #fff; }

.book-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.07);
  gap: 16rpx;
}
.book-emoji { font-size: 50rpx; line-height: 1; flex-shrink: 0; }
.book-info { flex: 1; min-width: 0; }
.book-title {
  display: block;
  font-size: 28rpx; font-weight: 700; color: #333;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.book-sub { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.book-arrow { font-size: 40rpx; color: #ccc; flex-shrink: 0; }
