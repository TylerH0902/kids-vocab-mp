page { background: #080C24; }

.page {
  position: relative;
  width: 750rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  background: #080C24;
}

.planet-canvas {
  width: 750rpx;
  height: 750rpx;
  display: block;
  flex-shrink: 0;
}

/* Header floats on top of canvas */
.header-overlay {
  position: absolute;
  top: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx 0;
  z-index: 10;
}

.app-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFD93D;
  text-shadow: 0 0 20rpx rgba(255,217,61,0.5);
}

.lang-row { display: flex; gap: 12rpx; }
.lang-btn {
  padding: 8rpx 22rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255,217,61,0.6);
  color: #FFD93D;
  font-size: 24rpx;
  font-weight: 700;
}
.lang-btn.active {
  background: #FFD93D;
  color: #080C24;
}

.hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  margin-top: 10rpx;
  text-align: center;
  letter-spacing: 1rpx;
}
