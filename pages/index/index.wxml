<view class="page">

  <canvas
    id="planet-canvas"
    type="2d"
    class="planet-canvas"
    bindtouchstart="onTouchStart"
    catchtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  ></canvas>

  <!-- Header floats over planet -->
  <view class="header-overlay">
    <text class="app-title">🌟 {{lang==='en'?'Story Quest':'故事大冒险'}}</text>
    <view class="lang-row">
      <view class="lang-btn {{lang==='en'?'active':''}}" bindtap="setLang" data-val="en">EN</view>
      <view class="lang-btn {{lang==='zh'?'active':''}}" bindtap="setLang" data-val="zh">中</view>
    </view>
  </view>

  <text class="hint">{{lang==='en'?'swipe to spin · tap a star to play':'左右滑动 · 点击星球探索'}}</text>

</view>
