<view class="page">

  <canvas
    id="planet-canvas"
    type="2d"
    class="planet-canvas"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  ></canvas>

  <!-- Placeholder shown while canvas initialises — prevents black flash -->
  <view class="map-loader" wx:if="{{!canvasReady}}"></view>

  <!-- Header floats over map -->
  <view class="header-overlay">
    <view class="header-right">
      <view class="lang-row">
        <view class="lang-btn {{lang==='en'?'active':''}}" bindtap="setLang" data-val="en">EN</view>
        <view class="lang-btn {{lang==='zh'?'active':''}}" bindtap="setLang" data-val="zh">中</view>
      </view>
      <view class="mode-row">
        <view class="mode-btn {{mode==='quest'?'active':''}}" bindtap="setMode" data-val="quest">⚔️ Quest</view>
        <view class="mode-btn {{mode==='trial'?'active':''}}" bindtap="setMode" data-val="trial">🌟 Trial</view>
      </view>
      <view class="profile-btn" bindtap="goProfile">👤</view>
    </view>
  </view>

  <text class="hint {{hintVisible?'':'hint-hidden'}}">{{hintText}}</text>

</view>
