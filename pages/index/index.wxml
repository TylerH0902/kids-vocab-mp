<view class="page">

  <!-- Header row -->
  <view class="header-row">
    <text class="title">📚 {{lang==='en'?'Book Quiz':'书本问答'}}</text>
    <view class="lang-row">
      <view class="lang-btn {{lang==='en'?'active':''}}" bindtap="setLang" data-val="en">EN</view>
      <view class="lang-btn {{lang==='zh'?'active':''}}" bindtap="setLang" data-val="zh">中</view>
    </view>
  </view>

  <!-- Book list -->
  <view wx:for="{{books}}" wx:key="id" class="book-card" bindtap="openBook" data-id="{{item.id}}">
    <text class="book-emoji">{{item.emoji}}</text>
    <view class="book-info">
      <text class="book-title">{{lang==='en'?item.title_en:item.title_zh}}</text>
      <text class="book-sub">{{lang==='en'?item.sub_en:item.sub_zh}}</text>
    </view>
    <text class="book-arrow">›</text>
  </view>

</view>
