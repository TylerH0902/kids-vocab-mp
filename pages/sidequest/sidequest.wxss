.page {
  min-height: 100vh;
  padding: 30rpx 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  position: relative;
}

.bg-image {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}

.bg-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(15, 5, 30, 0.68);
  z-index: 1;
}

.lang-row,
.balance-bar,
.header,
.book-list,
.btn-back { position: relative; z-index: 2; }

.lang-row { display: flex; gap: 12rpx; align-self: flex-end; }
.lang-btn {
  padding: 8rpx 20rpx; border-radius: 30rpx;
  border: 2rpx solid #a855f7; color: #a855f7;
  font-size: 24rpx; font-weight: 700;
}
.lang-btn.active { background: #a855f7; color: #fff; }

.header {
  display: flex; flex-direction: column; align-items: center;
  gap: 8rpx; margin-bottom: 12rpx;
}
.portal-icon { font-size: 100rpx; line-height: 1; }
.title {
  font-size: 52rpx; font-weight: 900; color: #e9d5ff;
  text-shadow: 0 0 20rpx rgba(168,85,247,.6);
}
.subtitle { font-size: 26rpx; color: rgba(233,213,255,.55); text-align: center; }

.book-list { width: 100%; display: flex; flex-direction: column; gap: 20rpx; }

.book-card {
  width: 100%; display: flex; align-items: center;
  background: rgba(168,85,247,.12);
  border: 2rpx solid rgba(168,85,247,.35);
  border-radius: 24rpx; padding: 24rpx 28rpx;
  gap: 24rpx;
}
.book-emoji { font-size: 72rpx; flex-shrink: 0; }
.book-info  { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.book-title { font-size: 34rpx; font-weight: 800; color: #f3e8ff; }
.book-sub   { font-size: 24rpx; color: rgba(243,232,255,.55); }

.stars-row  { display: flex; align-items: center; gap: 4rpx; }
.star       { font-size: 28rpx; color: rgba(255,255,255,.22); }
.star.lit   { color: #FFD700; text-shadow: 0 0 8rpx rgba(255,215,0,.7); }
.best-text  { font-size: 22rpx; color: rgba(243,232,255,.5); margin-left: 8rpx; }

.new-badge {
  display: inline-block; background: #a855f7;
  color: #fff; font-size: 20rpx; font-weight: 800;
  padding: 4rpx 14rpx; border-radius: 20rpx; align-self: flex-start;
}

.arrow { font-size: 50rpx; color: rgba(168,85,247,.6); flex-shrink: 0; }

.btn-back {
  margin-top: 16rpx; width: 100%; border-radius: 60rpx;
  background: rgba(168,85,247,.18);
  border: 2rpx solid rgba(168,85,247,.40);
  color: #d8b4fe; font-size: 32rpx; font-weight: 700;
  padding: 20rpx 0;
}

.balance-bar {
  display: flex; justify-content: space-between; align-items: center;
  width: 100%; background: rgba(168,85,247,.15);
  border-radius: 16rpx; padding: 16rpx 24rpx;
  box-sizing: border-box;
}
.balance-text { font-size: 28rpx; font-weight: 800; color: #FFD700; }
.btn-achievements {
  font-size: 24rpx; color: #d8b4fe;
  border: 1rpx solid rgba(168,85,247,.4);
  padding: 8rpx 16rpx; border-radius: 20rpx;
}

.locked-card { opacity: 0.75; }

.cost-row { display: flex; align-items: center; }
.cost-text { font-size: 26rpx; color: #FFD700; font-weight: 700; }

.btn-unlock {
  background: linear-gradient(135deg, #a855f7, #7c3aed);
  color: #fff; font-size: 26rpx; font-weight: 800;
  border-radius: 40rpx; padding: 12rpx 24rpx;
  min-width: 0; flex-shrink: 0;
  line-height: 1.4;
}
.btn-unlock-dim {
  background: rgba(168,85,247,.3);
  color: rgba(255,255,255,.5);
}
