.page {
  padding: 16rpx 20rpx 120rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Progress */
.prog-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}
.prog-bar-wrap {
  flex: 1;
  background: #e0e0e0;
  border-radius: 10rpx;
  height: 14rpx;
  overflow: hidden;
}
.prog-bar-fill {
  background: #6C63FF;
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s;
}
.prog-text {
  font-size: 24rpx;
  color: #888;
  white-space: nowrap;
}

/* Picture zone */
.picture-zone {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,.08);
  padding: 20rpx;
  text-align: center;
  margin-bottom: 20rpx;
  transition: background 0.2s;
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.picture-zone.correct { background: #e8f8e8; }
.picture-zone.wrong   { background: #fee8e8; }
.pic-img {
  width: 180rpx;
  height: 180rpx;
}
.big-emoji {
  font-size: 110rpx;
  line-height: 1;
}
.tap-hint {
  font-size: 28rpx;
  color: #ccc;
  margin-top: 8rpx;
}

/* Quiz zone */
.quiz-zone {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
}
.quiz-word {
  font-size: 48rpx;
  font-weight: 800;
  color: #6C63FF;
  margin-bottom: 10rpx;
}
.quiz-def {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* Choices */
.choices-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.choice-card {
  background: #fff;
  border: 4rpx solid #e8e8e8;
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  min-height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.choice-card.correct { border-color: #4CAF50; background: #e8f8e8; }
.choice-card.wrong   { border-color: #f44336; background: #fee8e8; }
.choice-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  word-break: break-all;
}

/* Feedback */
.feedback {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 99;
}
.feedback.correct { background: #4CAF50; }
.feedback.wrong   { background: #f44336; }
.fb-text  { color: #fff; font-size: 30rpx; font-weight: 700; }
.fb-next  { color: #fff; font-size: 28rpx; font-weight: 700; padding: 10rpx 20rpx; }

/* Back */
.back-row { margin-top: 16rpx; text-align: center; }
.back-btn { color: #999; font-size: 26rpx; }
