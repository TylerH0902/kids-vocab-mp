page {
  background: #F5F5FF;
  font-family: -apple-system, "PingFang SC", sans-serif;
  box-sizing: border-box;
}

/* ── Shared buttons ── */
.btn-primary {
  background: #6C63FF;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 18rpx 0;
  width: 100%;
  text-align: center;
}
.btn-primary[disabled] {
  background: #ccc;
}
.btn-secondary {
  background: #fff;
  color: #6C63FF;
  border: 2rpx solid #6C63FF;
  border-radius: 20rpx;
  font-size: 28rpx;
  padding: 14rpx 0;
  width: 100%;
  text-align: center;
}

/* ── Card grid ── */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.card-grid .card {
  flex: 1 1 calc(50% - 8rpx);
  background: #fff;
  border: 4rpx solid #e8e8e8;
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  transition: background 0.15s;
}
.card.selected  { border-color: #6C63FF; background: #EEF; }
.card.correct   { border-color: #4CAF50; background: #e8f8e8; color: #2e7d32; }
.card.wrong     { border-color: #f44336; background: #fee8e8; color: #c62828; }

/* ── Progress bar ── */
.prog-bar-wrap {
  background: #e0e0e0;
  border-radius: 10rpx;
  height: 14rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.prog-bar-fill {
  background: #6C63FF;
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s;
}
